# LLM backend: openai (OpenAI-compatible chat) | anthropic (Anthropic Messages)
LLM_PROVIDER=openai

# OpenAI-compatible: OpenAI, Groq, MiniMax OpenAI API, etc.
# MiniMax: https://platform.minimax.io/docs/api-reference/text-openai-api
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Messages: Claude, MiniMax Anthropic API, etc.
# MiniMax: https://platform.minimax.io/docs/api-reference/text-anthropic-api
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=16384

# Tavily (MCP: npx -y tavily-mcp). Optional. If TAVILY_API_KEY is set, planning uses web search automatically (Node on PATH).
TAVILY_API_KEY=

# Optional tuning (see README). Examples:
# CLIP_ENGINE_LONGFORM_MAX_S=360
# CLIP_ENGINE_SHORTFORM_MAX_S=80
# CLIP_ENGINE_SNAP_DURATION_SLACK_S=3
